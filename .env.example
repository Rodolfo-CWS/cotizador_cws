# Variables de entorno para el Cotizador CWS (Render)
# Copia este archivo como .env y configura tus valores

# Configuración de Flask
FLASK_DEBUG=False
SECRET_KEY=tu-clave-secreta-super-segura-aqui
APP_NAME=CWS Cotizaciones
APP_VERSION=2.2.0

# Supabase PostgreSQL (Base de datos principal)
SUPABASE_URL=https://tu-proyecto-id.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_KEY=tu-service-key
DATABASE_URL=postgresql://...

# Google Drive (Fallback storage)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
GOOGLE_DRIVE_FOLDER_NUEVAS=1h4DF0bdInRU5GUh9n7g8aXgZA4Kyt2Nf
GOOGLE_DRIVE_FOLDER_ANTIGUAS=1GqM9yfwUKd9n8nN97IUiBSUrWUZ1Vida

# Configuración de paginación
DEFAULT_PAGE_SIZE=20

# Configuración de entorno
FLASK_ENV=production

# Anthropic API (Claude - IA para generación de texto)
ANTHROPIC_API_KEY=sk-ant-...
